# Copy to .env.local and fill in. On Vercel, set these in Project Settings → Environment Variables.

# Supabase — get these from your Supabase project (Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Optional: only needed by /scripts (seed loader, admin tasks). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: only needed if you wire Phase 3 seed generation via the Anthropic API.
ANTHROPIC_API_KEY=
